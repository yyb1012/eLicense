MODEL_PROVIDER=openai
MODEL_NAME=gpt-5.4-mini
MODEL_API_KEY=your_api_key
MODEL_TIMEOUT_SECONDS=30

INGEST_STORE_SQLITE_PATH=.runtime/document_ingest.db
INGEST_CHUNK_MAX_TOKENS=500
INGEST_CHUNK_MAX_CHARS=2400
INGEST_CHUNK_OVERLAP=80
INGEST_EMBEDDING_PROVIDER=openai
INGEST_EMBEDDING_MODEL=text-embedding-3-small
INGEST_EMBEDDING_DIMENSION=1536
INGEST_EMBEDDING_TIMEOUT_SECONDS=20
INGEST_EMBEDDING_MAX_RETRIES=2
INGEST_EMBEDDING_BATCH_SIZE=16
INGEST_EMBEDDING_VERSION=v1

OCR_PROVIDER=paddleocr
OCR_ENABLED=true

POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/elicense
REDIS_URL=redis://localhost:6379/0
OBJECT_STORAGE_ENDPOINT=http://localhost:9000

LOG_LEVEL=INFO

FEATURE_ENABLE_WRITEBACK=false
FEATURE_ENABLE_INSPECTION_AGENT=false
